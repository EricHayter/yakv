          <mxGeometry height="30" width="260" x="20" y="496" as="geometry" />
        </mxCell>
        <mxCell id="page3-box" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" value="Page 3: Data Block 2" vertex="1">
