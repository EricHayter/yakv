<mxfile host="Electron" agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.3.6 Chrome/140.0.7339.249 Electron/38.8.0 Safari/537.36" version="29.3.6">
  <diagram name="SSTable File Format" id="sstable-diagram">
    <mxGraphModel dx="2848" dy="1690" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="EwI94tb1klGGUtJ_oxIb-49" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Helvetica;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;The Anatomy of a YAKV SSTable&lt;/span&gt;&lt;/h1&gt;&lt;p&gt;YAKV chooses to use a LSM table as it&#39;s storage format. As such we needed to design a SSTable to persist data.&lt;br&gt;&lt;br&gt;The SSTable is composed of pages that are each 4KB (4096 bytes) to make fetching and writing operations fluid with existing buffer manager architecture.&lt;br&gt;&lt;br&gt;There consists of 4 pages inside of the SSTable:&lt;/p&gt;&lt;p&gt;1. the header block&lt;br&gt;2. the data block&lt;br&gt;3. the (bloom) filter block&lt;br&gt;4. the range block&lt;/p&gt;&lt;p&gt;Below is a rough outline of what an sstable might look like:&lt;/p&gt;" vertex="1">
          <mxGeometry height="380" width="210" x="30" y="22" as="geometry" />
        </mxCell>
        <mxCell id="overview-title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" value="Example SSTable Structure" vertex="1">
          <mxGeometry height="30" width="300" y="396" as="geometry" />
        </mxCell>
        <mxCell id="page0-box" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" value="Page 0: Header" vertex="1">
          <mxGeometry height="30" width="260" x="20" y="436" as="geometry" />
        </mxCell>
